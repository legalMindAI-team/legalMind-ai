# ============================================
# LegalMind AI — Environment Variables
# ============================================
# Copy this file to .env and fill in your keys
# cp .env.example .env

# Groq API (free LLM — development)
# Get key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key_here

# OpenAI API (production LLM + embeddings)
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_key_here

# Cohere API (reranking — free tier available)
# Get key from: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your_cohere_key_here

# Environment: "development" or "production"
# development = uses Groq (free) + sentence-transformers (local)
# production = uses OpenAI GPT-4o + OpenAI embeddings
ENVIRONMENT=development

# ChromaDB persistent storage path
CHROMA_PERSIST_DIR=./chroma_data

# Server config
AI_SERVICE_PORT=8001
